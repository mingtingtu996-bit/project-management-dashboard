{
  "name": "project-management-dashboard",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "overrides": {
    "vite": {
      "esbuild": "^0.25.0"
    }
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "build": "npm run build --workspace=client && npm run build --workspace=server",
    "build:client": "npm run build --workspace=client",
    "build:server": "npm run build --workspace=server",
    "env:local": "node scripts/switch-env.mjs local",
    "env:prod": "node scripts/switch-env.mjs production",
    "env:status": "node scripts/switch-env.mjs status",
    "migrate:health-history": "node server/run-migration-029-health-history.mjs",
    "health:snapshot": "npm run health:snapshot --workspace=server",
    "diag:health": "node server/scripts/check-core-health.mjs",
    "diag:rls": "node server/scripts/check-public-rls.mjs",
    "diag:summary": "node server/scripts/check-summary-consistency.mjs",
    "diag:warning": "node server/scripts/check-warning-pipeline.mjs",
    "openai:image": "node scripts/generate-gpt-image-2.mjs",
    "prepare:test-env:full-app": "node scripts/prepare-full-app-test-env.mjs",
    "verify:company-cockpit": "node scripts/verify-company-cockpit-browser.mjs",
    "verify:dashboard": "node scripts/verify-dashboard-browser.mjs",
    "verify:gantt": "node scripts/verify-gantt-browser.mjs",
    "verify:notifications": "node scripts/verify-notifications-browser.mjs",
    "verify:drawings": "node scripts/verify-drawings-browser.mjs",
    "verify:responsibility": "node scripts/verify-responsibility-browser.mjs",
    "verify:task-summary": "node scripts/verify-task-summary-browser.mjs",
    "verify:acceptance": "node scripts/verify-acceptance-browser.mjs",
    "verify:reports": "node scripts/verify-reports-browser.mjs",
    "verify:materials": "node scripts/verify-materials-browser.mjs",
    "verify:gantt-change-log": "node scripts/verify-gantt-change-log-browser.mjs",
    "verify:risk-management": "node scripts/verify-risk-management-browser.mjs",
    "verify:planning-monthly": "node scripts/verify-planning-monthly-browser.mjs",
    "verify:pre-milestones": "node scripts/verify-pre-milestones-browser.mjs",
    "verify:milestones": "node scripts/verify-milestones-browser.mjs",
    "verify:planning-baseline": "node scripts/verify-planning-baseline-browser.mjs",
    "verify:planning-closeout": "node scripts/verify-planning-closeout-browser.mjs",
    "verify:team-members": "node scripts/verify-team-members-browser.mjs",
    "verify:join-project": "node scripts/verify-join-project-browser.mjs",
    "verify:planning-revision": "node scripts/verify-planning-revision-browser.mjs",
    "verify:planning-deviation": "node scripts/verify-planning-deviation-browser.mjs",
    "verify:planning-confirm-failure": "node scripts/verify-planning-confirm-failure-browser.mjs",
    "verify:wbs-templates": "node scripts/verify-wbs-templates-browser.mjs",
    "verify:planning-fine-flows": "node scripts/verify-planning-fine-flows-browser.mjs",
    "verify:risk-guard": "node scripts/verify-risk-guard-browser.mjs",
    "verify:monitoring": "node scripts/verify-monitoring-browser.mjs",
    "verify:workflow-contract": "npm test --workspace=server -- src/__tests__/deployWorkflowContract.test.ts",
    "deploy:cloudbase:backend": "node scripts/deploy-cloudbase-backend.mjs",
    "deploy:lighthouse:up": "docker compose -f deploy/docker-compose.lighthouse.yml up -d --build",
    "deploy:lighthouse:down": "docker compose -f deploy/docker-compose.lighthouse.yml down",
    "github:protect-main": "node scripts/configure-branch-protection.mjs main",
    "verify:browser-suite:shell-and-collab": "node scripts/run-browser-suite.mjs verify:company-cockpit verify:responsibility verify:dashboard verify:notifications verify:task-summary verify:team-members verify:join-project",
    "verify:browser-suite:project-chains": "node scripts/run-browser-suite.mjs verify:gantt verify:gantt-change-log verify:drawings verify:acceptance verify:reports verify:risk-management verify:risk-guard verify:pre-milestones verify:milestones",
    "verify:browser-suite:planning-and-tooling": "node scripts/run-browser-suite.mjs verify:planning-monthly verify:planning-baseline verify:planning-closeout verify:planning-revision verify:planning-deviation verify:planning-confirm-failure verify:planning-fine-flows verify:wbs-templates verify:monitoring",
    "acceptance:v1": "npx vitest run --root client src/pages/__tests__/sharedSummary.test.tsx src/pages/__tests__/GanttView.test.tsx src/pages/__tests__/Notifications.test.tsx && npx vitest run --root server src/__tests__/projectCreationSummaryChain.test.ts src/__tests__/taskCompletionSummaryChain.test.ts src/__tests__/riskNotificationChain.test.ts"
  },

  "devDependencies": {
    "concurrently": "^8.2.2",
    "esbuild": "^0.25.12",
    "pg": "^8.20.0"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "multer": "^2.1.1",
    "playwright": "^1.58.2"
  }
}
