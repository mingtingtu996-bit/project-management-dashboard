# ============================================
# 项目管理工具 - 前端环境配置模板
# ============================================
# 推荐做法：开发/上线都统一走 backend 模式，由前端只访问 /api 或正式后端域名，避免浏览器直连 Supabase 造成跨域与链路分叉。
# 首次初始化后可直接用：
#   npm run env:local
#   npm run env:prod -- --origin=https://app.example.com --api=/api

# ============================================
# 存储 / 接口模式
# ============================================
# 可选值: "local" | "backend" | "supabase"
# 当前推荐: backend
VITE_STORAGE_MODE=backend

# 后端 API 基地址
# 本地联调推荐 /api（走 Vite 代理）
# 生产环境可继续 /api（同域反代）或改成 https://api.example.com/api
VITE_API_BASE_URL=/api

# ============================================
# Supabase 配置（仅当需要远程同步或直连能力时使用）
# ============================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# ============================================
# 应用配置
# ============================================
VITE_APP_NAME=项目管理工具
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# ============================================
# 功能开关
# ============================================
VITE_ENABLE_REALTIME=true
VITE_ENABLE_ANALYTICS=false
VITE_DEBUG_MODE=false

# ============================================
# 监控配置（Sentry）
# ============================================
VITE_SENTRY_DSN=
VITE_MONITORING_ENABLED=true
