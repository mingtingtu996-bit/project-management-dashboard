# Copy this file to deploy/env/server.production.env before running docker compose.

PORT=3001
HOST=0.0.0.0
NODE_ENV=production
WEB_PORT=80
TRUST_PROXY_HOPS=1

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_KEY_HERE
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

SUPABASE_HOST=db.your-project.supabase.co
SUPABASE_PORT=5432
SUPABASE_DATABASE=postgres
SUPABASE_USER=postgres
SUPABASE_PASSWORD=YOUR_DATABASE_PASSWORD_HERE

CORS_ORIGIN=http://YOUR_SERVER_IP
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET
LOG_LEVEL=info
LOG_PERSIST=true
LOG_DIR=/app/logs
LOG_FILE_PATH=/app/logs/server.log
NOTIFICATION_READ_SYNC_TTL_MS=60000
NOTIFICATION_READ_SYNC_DELAY_MS=250
PROJECT_LIST_CACHE_TTL_MS=15000
API_RATE_LIMIT_MAX=2000
AUTH_RATE_LIMIT_MAX=20

# Keep the Postgres pool warm between normal user interactions.
DB_POOL_MAX=20
DB_POOL_WARM_CONNECTIONS=2
DB_IDLE_TIMEOUT_MS=300000
DB_CONNECTION_TIMEOUT_MS=5000
