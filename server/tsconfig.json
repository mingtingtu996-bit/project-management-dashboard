{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": false,
    "customConditions": [],
    "types": ["node", "vitest/globals"]
  },
  "include": ["src/**/*"],
  "ts-node": {
    "esm": true
  }
}
