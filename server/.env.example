# ============================================
# 项目管理工具 - 服务器环境配置模板
# ============================================
# 使用方法：复制此文件为 .env 并填入实际值
# 首次初始化后可直接用：
#   npm run env:local
#   npm run env:prod -- --origin=https://app.example.com --api=/api

# ─── 服务器配置 ───────────────────────────
PORT=3001
# 生产环境必须显式设置为 production，否则服务拒绝启动
NODE_ENV=development

# ─── 开发模式配置（仅 NODE_ENV=development 生效）────
# 本地调试时，无 Token 请求会使用此 UUID 作为当前用户
# 请填写你在 Supabase 中实际存在的用户 ID（不要硬编码到代码里）
DEV_USER_ID=YOUR_LOCAL_USER_UUID_HERE

# ─── Supabase 配置 ────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# ─── CORS 配置 ───────────────────────────
# 本地联调示例：
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
# 生产环境示例：
# CORS_ORIGIN=https://app.example.com

# ─── JWT 配置 ─────────────────────────────
# 必须使用强随机密钥（32+字符）
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET
JWT_ACCESS_EXPIRES_IN=7d

# ─── 日志配置 ─────────────────────────────
LOG_LEVEL=info

# ─── 数据库直连配置（用于迁移脚本）───────
DB_PASSWORD=YOUR_DATABASE_PASSWORD_HERE
