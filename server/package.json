{
  "name": "project-management-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx -r dotenv/config src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest --run",
    "test:watch": "vitest",
    "health:snapshot": "tsx -r dotenv/config run-health-history-snapshot.ts"
  },

  "dependencies": {
